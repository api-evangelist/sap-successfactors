        "type": "http"
      },
      "http": {
        "method": "POST",
        "url": "https://{apiServer}/odata/v2/oauth/token",
        "body": {
          "type": "form-urlencoded",
          "data": [
            {
              "name": "grant_type",
              "value": ""
